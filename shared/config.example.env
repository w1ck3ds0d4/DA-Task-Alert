# ntfy.sh topic - pick something unique/random (topics are public!)
# Example: da-alert-a7f3b9c2e1d4
NTFY_TOPIC=da-alert-CHANGE-ME

# Polling interval in seconds (minimum 300 = 5 minutes)
POLL_INTERVAL=300

# Session cookie from browser DevTools
# Go to app.dataannotation.tech > F12 > Application > Cookies > copy the session cookie value
DA_SESSION_COOKIE=

# Enable desktop notifications (set to false on headless servers)
DESKTOP_NOTIFY=true

# Only alert for projects matching these keywords (comma-separated, empty = all paid projects)
KEYWORDS=

# Exclude projects containing these keywords (comma-separated)
# Refreshers and Reference Versions are unpaid training materials
EXCLUDE_KEYWORDS=refresher, reference version
