# DA-Task-Alert local monitor env.
# Copy to .env and fill in values; .env is gitignored.

# ntfy.sh topic for phone push notifications.
NTFY_TOPIC=

# Polling interval in seconds (minimum 300 enforced in code).
POLL_INTERVAL=300

# DigitalAssistant session cookie (required to read tasks).
DA_SESSION_COOKIE=

# Notification surfaces.
DESKTOP_NOTIFY=true
PHONE_NOTIFY=true

# Comma-separated keyword filters.
KEYWORDS=
EXCLUDE_KEYWORDS=refresher, reference version
